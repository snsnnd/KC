# Tech Club CMS 环境变量配置
# 复制此文件为 .env 或 /etc/tech-club-cms.env（systemd）

# --- 必需 ---
ADMIN_PASSWORD=                # 初始主管理员密码，首次启动创建 admin 账号时使用
SESSION_SECRET=                # 固定 64 位十六进制随机值，用于 HMAC/AES 密钥，切忌每次重启变化
PUBLIC_BASE_URL=https://example.com   # 站点公开地址（用于邮件中的链接）

# --- 可选 ---
PORT=3000                      # API 监听端口（默认 3000）
DATA_DIR=/var/lib/tech-club    # JSON 数据持久化目录
UPLOAD_DIR=/var/lib/tech-club/uploads   # 媒体上传目录
TRUST_PROXY_HOPS=1              # 反向代理跳数（默认 1，CDN/LB 后设为实际跳数）
COOKIE_SECURE=true             # Cookie 启用 Secure 标志（HTTPS 环境必须开启）
MANAGER_EMAIL=admin@example.com   # 默认管理员邮箱（未配置 content.json 时使用）

# --- 邮件 SMTP（可选）---
SMTP_HOST=smtp.qq.com          # SMTP 服务器地址（默认 smtp.qq.com）
SMTP_PORT=465                  # SMTP 端口（默认 465，TLS）
SMTP_USER=your-email@qq.com    # SMTP 登录邮箱
SMTP_PASS=your-auth-code       # SMTP 授权码（非邮箱密码）

# --- 过期时间 ---
EMAIL_APPROVAL_TTL_HOURS=24    # 邮件审批 Token 有效期（小时，默认 24，最大 72）
MEMBER_ACTIVATION_TTL_HOURS=168  # 成员激活码有效期（小时，默认 168 即 7 天，最大 720）
