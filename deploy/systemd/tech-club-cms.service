[Unit]
Description=Tech Club Content Management API
After=network.target

[Service]
Type=simple
User=www-data
Group=www-data
WorkingDirectory=/opt/tech-club-cms
EnvironmentFile=/etc/tech-club-cms.env
ExecStart=/usr/bin/node /opt/tech-club-cms/src/server.js
Restart=on-failure
RestartSec=3
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths=/var/lib/tech-club

[Install]
WantedBy=multi-user.target
